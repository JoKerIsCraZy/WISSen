{
  "name": "wissen",
  "version": "1.3.1",
  "private": true,
  "description": "Inoffizieller Scraper fuer das WISS Tocco-Schulportal (Noten + Stundenplan) mit Dashboard, Scheduler und Telegram-Bot",
  "license": "MIT",
  "main": "cli.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings=ExperimentalWarning src/cli.js",
    "preserve": "npm run build:web",
    "serve": "node --experimental-sqlite --no-warnings=ExperimentalWarning src/server.js",
    "build:web": "cd web-svelte && npm run build",
    "dev:web": "cd web-svelte && npm run dev",
    "setup": "playwright install chromium",
    "test": "node --experimental-sqlite --no-warnings=ExperimentalWarning --test test/unit/*.test.js",
    "test:coverage": "node --experimental-test-coverage --experimental-sqlite --no-warnings=ExperimentalWarning --test test/unit/*.test.js",
    "lint": "eslint src/ test/",
    "postinstall": "cd web-svelte && npm install",
    "prepare": "husky install || true",
    "version": "node scripts/sync-web-version.mjs && git add web-svelte/package.json site/package.json"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "marked": "^18.0.3",
    "playwright": "1.60.0",
    "sanitize-html": "^2.17.4",
    "semver": "^7.8.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "husky": "^9.0.0"
  }
}
