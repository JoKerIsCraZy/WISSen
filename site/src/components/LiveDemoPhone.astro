---
// Live, interactive PWA-Demo eingebettet in einen Phone-Frame.
// Nutzt /pwa-demo/mobile/ — die echte PWA, aber mit gemockten Daten.
//
// Visueller Stil mirror'd Showcase.astro (Notch, gerundete Ecken, Drop-Shadow,
// Ambient-Glow). Iframe selbst wird NICHT animiert sobald sichtbar — die Live-
// UI würde sonst während Reveals gegen die Wrapper-Animation arbeiten.
//
// Props (optional):
//   - id:       Anchor-ID für Hash-Links (default: 'demo')
//   - showCopy: Side-Narrative anzeigen (default: true)

interface Props {
  id?: string;
  showCopy?: boolean;
}

const { id = 'demo', showCopy = true } = Astro.props;
---

<section class="tm-live" id={id}>
  {showCopy && (
    <div class="tm-live__copy" data-reveal>
      <span class="tm-eyebrow">Live Demo</span>
      <h2 class="tm-live__title">Klick dich durch — keine Installation, keine Anmeldung.</h2>
      <p class="tm-live__text">
        Das Handy rechts ist <strong>kein Bild</strong>, sondern die echte
        Mobile-PWA von WISSen, die direkt im Browser läuft. Alle Daten
        sind Beispiel-Daten, alle Interaktionen sind real:
        Tabs wechseln, Module antippen, Stundenplan scrollen, Settings öffnen.
      </p>
      <ul class="tm-live__list">
        <li><span class="tm-bullet">●</span> Tippe auf <strong>Noten</strong> → Modul → ZP/LB-Detail-Sheet</li>
        <li><span class="tm-bullet">●</span> <strong>Plan</strong>-Tab → ganzer Stundenplan mit Raumwechseln</li>
        <li><span class="tm-bullet">●</span> Frische Einträge nach links wischen → entfernt</li>
        <li><span class="tm-bullet">●</span> Inline-Raumplan zeigt das Stockwerk live</li>
      </ul>
      <div class="tm-live__actions">
        <a href="/start/quick-start/" class="tm-link-arrow">Selber installieren <span aria-hidden="true">→</span></a>
        <a href="/features/mobile-pwa/" class="tm-link-arrow">PWA-Doku <span aria-hidden="true">→</span></a>
      </div>
    </div>
  )}

  <div class={`tm-live__visual${showCopy ? '' : ' tm-live__visual--solo'}`} data-reveal>
    <div class="tm-live__phone" aria-label="Live Demo der WISSen Mobile-PWA">
      <div class="tm-live__notch" aria-hidden="true"></div>

      <span class="tm-live__pill" aria-hidden="true">
        <span class="tm-live__pill-dot"></span>
        Demo-Modus · Mock-Daten
      </span>

      <div class="tm-live__screen">
        <!-- Explicit /index.html: in Astro dev-mode, public/ trailing-slash
             requests get hijacked by Starlight's catch-all route handler.
             Including the filename bypasses the route-matcher. -->
        <iframe
          src="/pwa-demo/mobile/index.html"
          title="WISSen PWA — Live Demo"
          loading="lazy"
          allow="clipboard-write"
          referrerpolicy="no-referrer"
          class="tm-live__iframe"
        ></iframe>

        <!-- Click-shield: prevents the iframe from capturing the user's
             mouse wheel until they explicitly click "in". Click outside the
             phone to release. -->
        <button class="tm-live__shield" type="button" aria-label="Demo aktivieren — klicken zum Interagieren">
          <span class="tm-live__shield-hint">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="9 8 14 12 9 16"/>
            </svg>
            Klick zum Interagieren
          </span>
        </button>
      </div>
    </div>

    <div class="tm-live__glow" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* ==== Layout ==== */
  .tm-live {
    padding: clamp(3rem, 5vw, 6rem) clamp(1rem, 4vw, 2.5rem);
    max-width: 76rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    /* Smooth scroll target — schöner Anchor-Sprung von der Hero-CTA. */
    scroll-margin-top: 2rem;
  }
  @media (min-width: 880px) {
    .tm-live { grid-template-columns: 1.05fr 1fr; gap: 4rem; }
  }

  .tm-live__copy,
  .tm-live__visual {
    transition: opacity 700ms ease, transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  html.tm-anim .tm-live__copy[data-reveal]:not(.is-visible)   { opacity: 0; transform: translateX(-20px); }
  html.tm-anim .tm-live__visual[data-reveal]:not(.is-visible) { opacity: 0; transform: translateX(20px); }

  .tm-live__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .tm-live__visual--solo { margin: 0 auto; }

  .tm-eyebrow {
    display: inline-block;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tm-indigo-300);
    background: color-mix(in oklab, var(--tm-indigo-500) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--tm-indigo-500) 30%, transparent);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
  }
  :root[data-theme='light'] .tm-eyebrow {
    color: var(--tm-indigo-700);
    background: color-mix(in oklab, var(--tm-indigo-500) 10%, transparent);
  }

  .tm-live__title {
    font-size: clamp(1.75rem, 1.3rem + 1.5vw, 2.6rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.035em;
    margin: 0.65rem 0 1rem;
  }
  .tm-live__text {
    color: var(--sl-color-gray-2);
    font-size: 1.025rem; line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  .tm-live__list {
    list-style: none; padding: 0; margin: 0 0 1.5rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    font-size: 0.95rem; color: var(--sl-color-gray-2);
  }
  .tm-bullet {
    color: var(--tm-indigo-400);
    margin-right: 0.45rem; font-size: 0.55em; vertical-align: middle;
  }
  :root[data-theme='light'] .tm-bullet { color: var(--tm-indigo-600); }

  .tm-live__actions { display: flex; flex-wrap: wrap; gap: 1.25rem; }
  .tm-link-arrow {
    color: var(--tm-indigo-300); font-weight: 600; text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--tm-indigo-400) 40%, transparent);
    padding-bottom: 2px;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .tm-link-arrow:hover {
    color: var(--tm-indigo-200);
    border-bottom-color: var(--tm-indigo-300);
  }
  :root[data-theme='light'] .tm-link-arrow {
    color: var(--tm-indigo-700);
    border-bottom-color: color-mix(in oklab, var(--tm-indigo-600) 35%, transparent);
  }
  :root[data-theme='light'] .tm-link-arrow:hover { color: var(--tm-indigo-900); }

  /* ==== Phone shell — gleich proportioniert wie Showcase, aber kein Float ==== */
  .tm-live__phone {
    position: relative;
    width: clamp(280px, 32vw, 320px);
    aspect-ratio: 9 / 19.5;
    border-radius: 44px;
    background: linear-gradient(180deg, #1a1a24, #0a0a14);
    box-shadow:
      0 1px 0 1px rgba(255, 255, 255, 0.04) inset,
      0 0 0 7px #0a0a0f,
      0 35px 80px -20px rgba(0, 0, 0, 0.7),
      0 0 100px -10px color-mix(in oklab, var(--tm-indigo-500) 40%, transparent);
    padding: 9px;
    z-index: 1;
  }

  .tm-live__notch {
    position: absolute;
    top: 16px; left: 50%;
    transform: translateX(-50%);
    width: 96px; height: 26px;
    background: #000;
    border-radius: 16px;
    z-index: 3;
    pointer-events: none;
  }

  /* Pill: floating "Demo-Modus" Badge oben-rechts ÜBER dem Phone-Frame.
   * Position außerhalb des Screens damit es nicht den Iframe-Inhalt verdeckt. */
  .tm-live__pill {
    position: absolute;
    top: -14px;
    right: -8px;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: rgba(15, 17, 21, 0.95);
    border: 1px solid color-mix(in oklab, var(--tm-violet-500) 50%, transparent);
    border-radius: 999px;
    color: var(--sl-color-white);
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    box-shadow:
      0 6px 20px -4px rgba(0, 0, 0, 0.5),
      0 0 30px -8px color-mix(in oklab, var(--tm-violet-500) 60%, transparent);
    backdrop-filter: blur(12px);
    pointer-events: none;
  }
  .tm-live__pill-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: tm-live-pulse 2.4s ease-in-out infinite;
  }
  @keyframes tm-live-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }
  :root[data-theme='light'] .tm-live__pill {
    background: rgba(255, 255, 255, 0.95);
    color: var(--tm-indigo-800);
    border-color: color-mix(in oklab, var(--tm-violet-500) 40%, transparent);
  }

  .tm-live__screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 35px;
    background: #0f1115;
    overflow: hidden;
    isolation: isolate;
  }

  /* Click-to-activate overlay: by default, the iframe is non-interactive so
   * the user's mouse wheel scrolls the OUTER page even when hovering the
   * phone. Click anywhere on the phone → overlay disappears, iframe becomes
   * interactive. Click outside the phone → overlay returns. */
  .tm-live__shield {
    position: absolute;
    inset: 0;
    z-index: 4;
    border-radius: 35px;
    cursor: pointer;
    background: linear-gradient(180deg,
      rgba(10, 10, 15, 0) 60%,
      rgba(10, 10, 15, 0.55) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 22px;
    transition: opacity 220ms ease;
  }
  .tm-live__shield-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(15, 17, 21, 0.9);
    border: 1px solid color-mix(in oklab, var(--tm-indigo-500) 50%, transparent);
    color: var(--sl-color-white);
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    box-shadow: 0 0 24px -4px color-mix(in oklab, var(--tm-indigo-500) 60%, transparent);
    pointer-events: none;
  }
  .tm-live__shield-hint svg {
    color: var(--tm-indigo-300);
  }
  .tm-live__phone[data-active='true'] .tm-live__shield {
    opacity: 0;
    pointer-events: none;
  }

  /* Das Iframe füllt den Screen komplett. background-color matcht --pwa-bg
   * der echten PWA, damit es während des Ladens kein weißes Flash gibt. */
  .tm-live__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: #0f1115;
    color-scheme: dark;
    display: block;
  }

  /* ==== Glow hinter dem Phone ==== */
  .tm-live__glow {
    position: absolute;
    inset: 5% 5%;
    background: radial-gradient(ellipse at center,
      color-mix(in oklab, var(--tm-violet-500) 35%, transparent),
      transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }

  /* Reduced motion: kein Reveal-Slide, Pill-Dot-Pulse aus. */
  @media (prefers-reduced-motion: reduce) {
    .tm-live__pill-dot { animation: none !important; }
    html.tm-anim .tm-live__copy[data-reveal]:not(.is-visible),
    html.tm-anim .tm-live__visual[data-reveal]:not(.is-visible) {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  // Reveal-on-scroll
  const els = document.querySelectorAll<HTMLElement>('.tm-live__copy[data-reveal], .tm-live__visual[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.2 }
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-visible'));
  }

  // Click-to-activate / click-out-to-release shield over the iframe.
  // Reason: a same-origin iframe captures mouse-wheel events when the cursor
  // hovers it, so users can't scroll the page. The shield blocks pointer
  // events until they opt in by clicking. Clicking outside re-arms the shield.
  document.querySelectorAll<HTMLElement>('.tm-live__phone').forEach((phone) => {
    const shield = phone.querySelector<HTMLButtonElement>('.tm-live__shield');
    if (!shield) return;

    shield.addEventListener('click', (e) => {
      e.stopPropagation();
      phone.dataset.active = 'true';
    });

    document.addEventListener('click', (e) => {
      if (phone.dataset.active !== 'true') return;
      const t = e.target as Node | null;
      if (t && !phone.contains(t)) {
        phone.dataset.active = 'false';
      }
    });

    // ESC also releases.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && phone.dataset.active === 'true') {
        phone.dataset.active = 'false';
      }
    });
  });
</script>
