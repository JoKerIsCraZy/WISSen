---
const features = [
  {
    icon: 'dashboard',
    title: 'Noten-Dashboard',
    text: 'SvelteKit-SPA mit Filtern, Modul-Detail, IPA-Rechner und Statistiken.',
    href: '/features/dashboard/',
  },
  {
    icon: 'phone',
    title: 'Mobile-App (PWA)',
    text: 'Installierbar auf iOS & Android — fühlt sich an wie eine native App.',
    href: '/features/mobile-pwa/',
  },
  {
    icon: 'bell',
    title: 'Push-Notifications',
    text: 'Native Web-Push bei neuen Noten und Zimmerwechseln — auch bei geschlossener App.',
    href: '/features/push/',
  },
  {
    icon: 'chat',
    title: 'Telegram-Bot',
    text: 'Live-Tracking, manuelle Scrapes und Inline-Menüs direkt in Telegram.',
    href: '/features/telegram/',
  },
  {
    icon: 'calendar',
    title: 'Stundenplan',
    text: 'Tages-, Wochen- und Monatsansicht mit Raumwechsel-Highlights.',
    href: '/features/stundenplan-noten/',
  },
  {
    icon: 'shield',
    title: 'Sicher by default',
    text: 'AES-256-GCM-Encryption-at-Rest, Bearer-Token, Anti-Brute-Force.',
    href: '/konfiguration/sicherheit/',
  },
  {
    icon: 'docker',
    title: 'Docker-First',
    text: 'Ein Befehl, fertig. Multi-Stage-Build, Non-Root-User, Health-Checks.',
    href: '/docker/deployment/',
  },
  {
    icon: 'archive',
    title: 'SQLite-Historie',
    text: 'Append-only Verlauf jeder Note, jeder LB/ZP-Bewertung — niemals überschrieben.',
    href: '/features/stundenplan-noten/',
  },
];
---

<section class="tm-features">
  <header class="tm-features__head">
    <span class="tm-eyebrow">Features</span>
    <h2 class="tm-features__title">Alles, was Tocco hätte sein sollen.</h2>
    <p class="tm-features__sub">
      Eine Plattform für alle Geräte — desktop, mobil, Telegram. Alles aus einem
      Container, alles auf deinem Server.
    </p>
  </header>

  <div class="tm-features__grid">
    {features.map((f) => (
      <a class="tm-feature" href={f.href} data-reveal>
        <span class="tm-feature__glow" aria-hidden="true"></span>
        <span class="tm-feature__icon">
          {f.icon === 'dashboard' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="7" height="9"/>
              <rect x="14" y="3" width="7" height="5"/>
              <rect x="14" y="12" width="7" height="9"/>
              <rect x="3" y="16" width="7" height="5"/>
            </svg>
          )}
          {f.icon === 'phone' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="6" y="2" width="12" height="20" rx="3"/>
              <line x1="11" y1="18" x2="13" y2="18"/>
            </svg>
          )}
          {f.icon === 'bell' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
              <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
            </svg>
          )}
          {f.icon === 'chat' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          )}
          {f.icon === 'calendar' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          )}
          {f.icon === 'shield' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          )}
          {f.icon === 'docker' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="3" height="3"/>
              <rect x="7" y="11" width="3" height="3"/>
              <rect x="11" y="11" width="3" height="3"/>
              <rect x="7" y="7" width="3" height="3"/>
              <rect x="11" y="7" width="3" height="3"/>
              <rect x="11" y="3" width="3" height="3"/>
              <path d="M22 13c-2 4-7 5-12 5-3.7 0-7-1-7-1"/>
            </svg>
          )}
          {f.icon === 'archive' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="21 8 21 21 3 21 3 8"/>
              <rect x="1" y="3" width="22" height="5"/>
              <line x1="10" y1="12" x2="14" y2="12"/>
            </svg>
          )}
        </span>
        <h3 class="tm-feature__title">
          {f.title}
          <span class="tm-feature__arrow" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <line x1="2.5" y1="8" x2="13" y2="8"/>
              <polyline points="9 4 13 8 9 12"/>
            </svg>
          </span>
        </h3>
        <p class="tm-feature__text">{f.text}</p>
      </a>
    ))}
  </div>
</section>

<style>
  .tm-features {
    padding: clamp(3rem, 5vw, 6rem) clamp(1rem, 4vw, 2.5rem);
    max-width: 76rem;
    margin: 0 auto;
  }

  .tm-features__head {
    text-align: center;
    margin-bottom: clamp(2.25rem, 3vw, 3.75rem);
  }

  .tm-eyebrow {
    display: inline-block;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--tm-indigo-400);
    margin-bottom: 0.85rem;
  }
  :root[data-theme='light'] .tm-eyebrow { color: var(--tm-indigo-600); }

  .tm-features__title {
    font-size: clamp(1.85rem, 1.4rem + 1.6vw, 3rem);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.035em;
    margin: 0 0 0.85rem;
  }

  .tm-features__sub {
    max-width: 40rem;
    margin: 0 auto;
    color: var(--sl-color-gray-2);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .tm-features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr));
    gap: 0.875rem;
  }

  .tm-feature {
    --tm-glow-x: 50%;
    --tm-glow-y: 0%;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    /* Asymmetric padding: more breathing room below to anchor weight,
       a little extra at top to let the icon sit clean. */
    padding: 1.5rem 1.35rem 1.65rem;
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    background:
      linear-gradient(180deg,
        color-mix(in oklab, var(--sl-color-bg) 96%, var(--tm-indigo-500) 4%),
        color-mix(in oklab, var(--sl-color-bg) 99%, transparent));
    border: 1px solid var(--sl-color-hairline);
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms ease,
      box-shadow 320ms ease,
      background 320ms ease;
    opacity: 0;
    transform: translateY(14px);
    will-change: transform;
  }

  .tm-feature[data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
    transition:
      transform 540ms cubic-bezier(0.16, 1, 0.3, 1) var(--tm-delay, 0ms),
      opacity 540ms ease var(--tm-delay, 0ms),
      border-color 320ms ease,
      box-shadow 320ms ease,
      background 320ms ease;
  }

  /* Cursor-tracking glow: tighter radius, sharper falloff so it feels
     like a real spotlight, not a wash. */
  .tm-feature__glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      220px circle at var(--tm-glow-x) var(--tm-glow-y),
      color-mix(in oklab, var(--tm-indigo-500) 22%, transparent) 0%,
      color-mix(in oklab, var(--tm-violet-500) 10%, transparent) 28%,
      transparent 55%
    );
    opacity: 0;
    transition: opacity 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Hairline accent that sweeps in on hover — felt, not loud. */
  .tm-feature::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--tm-indigo-500) 55%, transparent),
      transparent 45%,
      color-mix(in oklab, var(--tm-violet-500) 40%, transparent)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 1;
  }

  .tm-feature > * {
    position: relative;
    z-index: 2;
  }

  .tm-feature:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklab, var(--tm-indigo-500) 35%, var(--sl-color-hairline));
    box-shadow:
      0 1px 0 0 color-mix(in oklab, var(--tm-indigo-300) 12%, transparent) inset,
      0 22px 44px -22px color-mix(in oklab, var(--tm-indigo-600) 45%, transparent);
  }
  .tm-feature:hover .tm-feature__glow { opacity: 1; }
  .tm-feature:hover::after { opacity: 1; }

  .tm-feature:active {
    transform: translateY(-1px);
    transition-duration: 120ms;
  }

  .tm-feature:focus-visible {
    outline: 2px solid var(--tm-indigo-400);
    outline-offset: 3px;
  }

  .tm-feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    border-radius: 10px;
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--tm-indigo-500) 18%, transparent),
      color-mix(in oklab, var(--tm-violet-500) 18%, transparent));
    color: var(--tm-indigo-300);
    border: 1px solid color-mix(in oklab, var(--tm-indigo-500) 28%, transparent);
    transition:
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 320ms ease,
      color 320ms ease;
  }
  :root[data-theme='light'] .tm-feature__icon { color: var(--tm-indigo-700); }
  .tm-feature__icon svg { width: 20px; height: 20px; }

  .tm-feature:hover .tm-feature__icon {
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--tm-indigo-500) 55%, transparent);
    color: var(--tm-indigo-200);
  }
  :root[data-theme='light'] .tm-feature:hover .tm-feature__icon { color: var(--tm-indigo-800); }

  /* Title + arrow share a row: arrow lives at the title's baseline so it
     pulls the eye toward the action, not floating in dead space. */
  .tm-feature__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.018em;
    line-height: 1.25;
    margin: 0.15rem 0 0;
    color: var(--sl-color-white);
  }
  :root[data-theme='light'] .tm-feature__title { color: var(--sl-color-text); }

  .tm-feature__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: var(--tm-indigo-400);
    opacity: 0.55;
    transform: translateX(-2px);
    transition:
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 220ms ease,
      color 220ms ease;
  }
  .tm-feature__arrow svg { width: 14px; height: 14px; display: block; }
  :root[data-theme='light'] .tm-feature__arrow { color: var(--tm-indigo-600); }

  .tm-feature:hover .tm-feature__arrow {
    transform: translateX(2px);
    opacity: 1;
    color: var(--tm-indigo-300);
  }
  :root[data-theme='light'] .tm-feature:hover .tm-feature__arrow { color: var(--tm-indigo-700); }

  .tm-feature__text {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .tm-feature,
    .tm-feature__icon,
    .tm-feature__arrow,
    .tm-feature__glow,
    .tm-feature::after {
      transition: none !important;
    }
    .tm-feature {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  // Scroll reveal + cursor-tracking glow
  const cards = document.querySelectorAll<HTMLElement>('.tm-feature[data-reveal]');

  // Stagger: smooth diagonal cascade across the grid (2 cols/row baseline at
  // narrow widths, up to 4 at wide). Cap delay so late items don't lag.
  cards.forEach((c, i) => {
    const delay = Math.min(i * 55, 360);
    c.style.setProperty('--tm-delay', `${delay}ms`);
  });

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );
    cards.forEach((c) => io.observe(c));
  } else {
    cards.forEach((c) => c.classList.add('is-visible'));
  }

  // Cursor-tracking glow with rAF batching so we don't hammer the
  // compositor on fast pointer movement.
  let frame = 0;
  cards.forEach((card) => {
    let pending: { x: number; y: number } | null = null;
    card.addEventListener('pointermove', (event) => {
      const e = event as PointerEvent;
      const rect = card.getBoundingClientRect();
      pending = { x: e.clientX - rect.left, y: e.clientY - rect.top };
      if (!frame) {
        frame = requestAnimationFrame(() => {
          frame = 0;
          if (!pending) return;
          card.style.setProperty('--tm-glow-x', `${pending.x}px`);
          card.style.setProperty('--tm-glow-y', `${pending.y}px`);
          pending = null;
        });
      }
    });
    card.addEventListener('pointerleave', () => {
      // Re-center for the next entry so it animates from a calm origin.
      card.style.setProperty('--tm-glow-x', '50%');
      card.style.setProperty('--tm-glow-y', '0%');
    });
  });
</script>
